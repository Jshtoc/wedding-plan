# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` to git.

# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Session token signing ─────────────────────────────────
# Used to HMAC-sign the session cookie. Replace with a long random string.
# Example: openssl rand -base64 48
AUTH_SECRET=replace-with-a-long-random-string

# ─── Fixed user accounts ───────────────────────────────────
# This project has exactly two accounts (husband + wife).
# Generate a hash from a plaintext password:
#   npm run hash-password -- "your-secure-password"
# Then paste the output into the corresponding USER*_PASSWORD_HASH below.

# Husband
USER1_ID=wed1
USER1_PASSWORD_HASH=
USER1_ROLE=husband

# Wife
USER2_ID=wed2
USER2_PASSWORD_HASH=
USER2_ROLE=wife
